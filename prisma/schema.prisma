generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  PARTNER
  CUSTOMER
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlanTier {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
}

enum CreditTxType {
  PURCHASE
  BONUS
  SPEND
  REFUND
  ADMIN
  SUBSCRIPTION
  TRANSFER
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  COMPLETED
  FAILED
  REFUNDED
}

enum QrDurationTier {
  FREE_TRIAL
  WEEKLY
  MONTHLY
  YEARLY
  PERMANENT
}

enum QrMode {
  STATIC
  DYNAMIC
}

enum QrType {
  URL
  TEXT
  GOOGLE_MAPS
  GOOGLE_REVIEW
  GEO
  WIFI
  WHATSAPP
  TELEGRAM
  SOCIAL
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
  LINKEDIN
  TWITTER
  SNAPCHAT
  SPOTIFY
  DISCORD
  LINK_BIO
  VCARD
  ME_CARD
  EMAIL
  PHONE
  SMS
  PDF
  APP_STORE
  PLAY_STORE
  IBAN
  CRYPTO
  PAYPAL
  PAYMENT_LINK
  ECOMMERCE
  PRODUCT
  MENU
  COUPON
  BOOKING
  FEEDBACK
  CATALOG
  MEMBERSHIP
  PARKING
  DONATION
  TABLE_ORDER
  INVENTORY
  EVENT
  VIDEO
  WARRANTY
  LCV
}

enum ActivityKind {
  QR_CREATED
  QR_UPDATED
  QR_DELETED
  USER_LOGIN
  ADMIN_LOGIN
  SIGNUP
  PAYMENT_CREATED
  PAYMENT_CLAIMED
  PAYMENT_APPROVED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
  PAYMENT_DELETED
  CREDIT_ADJUSTED
  CREDIT_RESET
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ORG_UPDATED
  ADMIN_BULK_ACTION
  STAFF_UPDATED
  SECURITY_BLOCKED
  SECURITY_LOGIN_FAILED
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  passwordHash     String
  name             String
  role             UserRole     @default(CUSTOMER)
  adminPermissions String       @default("[]")
  grantedById      String?
  grantedBy        User?        @relation("AdminGrants", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedAdmins    User[]       @relation("AdminGrants")
  grantedAt        DateTime?
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  memberships      Membership[]
  activityLogs     ActivityLog[]
}

model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  parentOrganizationId String?
  parentOrganization   Organization?    @relation("OrgHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  childOrganizations   Organization[]   @relation("OrgHierarchy")
  planTier           PlanTier           @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  credits            Int                @default(0)
  unlimitedCredits   Boolean            @default(false)
  qrCount            Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  memberships        Membership[]
  qrCodes            QrCode[]
  templates          QrTemplate[]
  creditTransactions CreditTransaction[]
  paymentOrders      PaymentOrder[]
  uploadedFiles      UploadedFile[]
  activityLogs       ActivityLog[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model CreditTransaction {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           CreditTxType
  amount         Int
  balanceAfter   Int
  description    String
  referenceId    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([createdAt])
}

model PaymentOrder {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packageId      String
  amountTry      Int
  credits        Int
  status         PaymentStatus @default(PENDING)
  provider       String        @default("internal")
  providerRef    String?
  metadata       String        @default("{}")
  createdAt      DateTime      @default(now())
  completedAt    DateTime?

  @@index([organizationId])
  @@index([status])
}

model QrCode {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           QrType
  mode           QrMode        @default(STATIC)
  shortCode      String?       @unique
  targetUrl      String?
  payload        String        @default("{}")
  design         String        @default("{}")
  description    String?
  customerName   String?
  projectName    String?
  productType    String?
  isActive       Boolean         @default(true)
  durationTier   QrDurationTier  @default(FREE_TRIAL)
  expiresAt      DateTime?
  scanCount      Int             @default(0)
  lastScannedAt  DateTime?
  templateId     String?
  template       QrTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  scans          QrScan[]
  linkBio        LinkBioPage?
  warrantyForm   WarrantyForm?
  lcvForm        LcvForm?
  files          UploadedFile[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([mode])
  @@index([isActive])
  @@index([createdAt])
}

model QrScan {
  id         String   @id @default(cuid())
  qrCodeId   String
  qrCode     QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  deviceType String?
  browser    String?
  os         String?
  country    String?
  city       String?
  ipHash     String?
  scannedAt  DateTime @default(now())

  @@index([qrCodeId])
  @@index([scannedAt])
}

model QrTemplate {
  id              String        @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystem        Boolean       @default(false)
  name            String
  qrType          QrType
  defaultTitle    String?
  defaultSubtitle String?
  design          String        @default("{}")
  dimensions      String?
  printFormat     String?
  notes           String?
  qrCodes         QrCode[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([isSystem])
}

model LinkBioPage {
  id          String   @id @default(cuid())
  qrCodeId    String   @unique
  qrCode      QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  slug        String   @unique
  title       String
  description String?
  logoUrl     String?
  bgColor     String   @default("#ffffff")
  buttonColor String   @default("#111827")
  links       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WarrantyForm {
  id            String                 @id @default(cuid())
  qrCodeId      String                 @unique
  qrCode        QrCode                 @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  slug          String                 @unique
  title         String                 @default("Garanti Aktivasyon")
  registrations WarrantyRegistration[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model WarrantyRegistration {
  id            String       @id @default(cuid())
  formId        String
  form          WarrantyForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  customerName  String
  phone         String
  email         String
  productName   String
  productModel  String?
  serialNumber  String
  purchaseDate  String?
  invoiceNumber String?
  purchasedFrom String?
  warrantyStart String?
  warrantyEnd   String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([serialNumber])
  @@index([customerName])
}

model LcvForm {
  id            String            @id @default(cuid())
  qrCodeId      String            @unique
  qrCode        QrCode            @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  slug          String            @unique
  eventName     String
  eventDate     String?
  title         String            @default("Katılım Formu")
  registrations LcvRegistration[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model LcvRegistration {
  id         String   @id @default(cuid())
  formId     String
  form       LcvForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  fullName   String
  phone      String
  attendance String
  guestCount Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())

  @@index([formId])
}

model UploadedFile {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  qrCodeId       String?
  qrCode         QrCode?       @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  category       String
  fileName       String
  mimeType       String
  size           Int
  path           String
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([category])
  @@index([qrCodeId])
}

model ActivityLog {
  id             String       @id @default(cuid())
  kind           ActivityKind
  actorUserId    String?
  actorUser      User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName      String?
  actorEmail     String?
  actorRole      String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  targetType     String?
  targetId       String?
  targetLabel    String?
  message        String
  metadata       String       @default("{}")
  createdAt      DateTime     @default(now())

  @@index([createdAt])
  @@index([kind])
  @@index([actorUserId])
  @@index([organizationId])
}
